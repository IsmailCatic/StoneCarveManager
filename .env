# --- SQL Server ---
# Must meet SQL Server password complexity (min 8 chars, mixed case, number, symbol)
DB_SA_PASSWORD=StoneCarve@Admin1234
# Full connection string — only set this to override the appsettings value.
# Leave empty/commented out to use appsettings.Development.json (LocalDB) when running locally.
# Docker Compose sets ConnectionStrings__MainDB directly, so this is not needed there.
# DB_CONNECTION_STRING=Server=localhost,1433;Database=StoneCarveManager;User Id=sa;Password=StoneCarve@Admin1234;TrustServerCertificate=True;MultipleActiveResultSets=true

# --- RabbitMQ ---
